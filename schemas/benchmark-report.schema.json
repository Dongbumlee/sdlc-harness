{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Benchmark Report",
  "description": "Schema for SDLC Harness benchmark run reports",
  "type": "object",
  "required": ["run_id", "timestamp", "harness_version", "results", "summary"],
  "properties": {
    "run_id": {
      "type": "string",
      "description": "Unique run identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "harness_version": {
      "type": "string",
      "description": "Version of the harness used"
    },
    "agent": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "profile": { "type": "string" },
        "canary_filter": { "type": "string" },
        "timeout_seconds": { "type": "integer" }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["canary_id", "status", "scores"],
        "properties": {
          "canary_id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "error", "timeout", "skipped"]
          },
          "scores": {
            "type": "object",
            "properties": {
              "overall": { "type": "number" },
              "by_grader": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "grader_type": { "type": "string" },
                    "score": { "type": "number" },
                    "weight": { "type": "number" },
                    "details": { "type": "object" }
                  }
                }
              }
            }
          },
          "duration_seconds": { "type": "number" },
          "error": { "type": "string" }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total", "passed", "failed"],
      "properties": {
        "total": { "type": "integer" },
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "errored": { "type": "integer" },
        "skipped": { "type": "integer" },
        "overall_score": { "type": "number" },
        "duration_seconds": { "type": "number" }
      }
    }
  }
}
