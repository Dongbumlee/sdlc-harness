{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evaluation Report",
  "description": "Schema for orchestrator evaluation reports — aggregated assessment of a full run",
  "type": "object",
  "required": ["evaluation_id", "run_id", "timestamp", "verdict", "phase_scores"],
  "properties": {
    "evaluation_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string",
      "description": "Reference to the benchmark run being evaluated"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail", "partial"],
      "description": "Overall evaluation verdict"
    },
    "overall_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "phase_scores": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "score": { "type": "number" },
          "canaries_passed": { "type": "integer" },
          "canaries_total": { "type": "integer" },
          "issues": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "trend": {
      "type": "object",
      "properties": {
        "direction": {
          "type": "string",
          "enum": ["improving", "stable", "degrading"]
        },
        "delta": { "type": "number" },
        "compared_to_run": { "type": "string" }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "warning", "info"]
          },
          "phase": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  }
}
