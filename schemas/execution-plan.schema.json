{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Execution Plan",
  "description": "Schema for orchestrator execution plans",
  "type": "object",
  "required": ["plan_id", "phases", "created_at"],
  "properties": {
    "plan_id": {
      "type": "string",
      "description": "Unique plan identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "requirement_summary": {
      "type": "string",
      "description": "Summary of the original requirement"
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "tasks"],
        "properties": {
          "phase": {
            "type": "string",
            "enum": ["requirements", "design", "implement", "qa", "deploy", "document", "rai", "release", "scaffold"]
          },
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "description", "agent"],
              "properties": {
                "id": { "type": "string" },
                "description": { "type": "string" },
                "agent": { "type": "string" },
                "skill": { "type": "string" },
                "depends_on": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "inputs": { "type": "object" },
                "timeout_seconds": { "type": "integer" }
              }
            }
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "properties": {
        "max_parallel": { "type": "integer" },
        "total_timeout_seconds": { "type": "integer" },
        "fail_fast": { "type": "boolean" }
      }
    }
  }
}
